{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "generic",
          "path": "VERSION"
        },
        {
          "type": "generic",
          "path": "docs-site/docs/intro.md"
        },
        {
          "type": "generic",
          "path": "docs-site/src/constants.ts"
        },
        {
          "type": "json",
          "path": "docs-site/package.json",
          "jsonPath": "$.version"
        }
      ],
      "exclude-paths": ["docs/**", "inventory/**"]
    }
  }
}
